{
  "name": "template-server",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "build:api": "redocly bundle docs/openapi.yaml -o docs/openapi.json --ext json && redocly build-docs docs/openapi.yaml -o docs/index.html",
    "lint:check": "eslint '**/*.{js,ts}'",
    "lint:fix": "eslint '**/*.{js,ts}' --fix",
    "start": "node --trace-warnings --abort-on-uncaught-exception dist/index.js",
    "dev": "nodemon --watch 'src/**' --ext 'ts,json' --ignore 'src/**/*.spec.ts' --ignore 'src/migrations' --exec 'yarn build && yarn start'",
    "test": "jest --forceExit --detectOpenHandles --coverage --verbose",
    "start:db": "docker-compose up -d && docker exec world_content_server_db bash -c \"until pg_isready; do sleep 1; done\" && sleep 5"
  },
  "dependencies": {
    "@dcl/catalyst-api-specs": "^3.3.0",
    "@dcl/catalyst-contracts": "^4.4.2",
    "@dcl/catalyst-storage": "^4.6.1",
    "@dcl/core-commons": "^0.10.1",
    "@dcl/crypto": "^3.7.0",
    "@dcl/crypto-middleware": "^4.1.1",
    "@dcl/fetch-component": "^1.1.1",
    "@dcl/hashing": "^3.0.4",
    "@dcl/http-commons": "^2.0.0",
    "@dcl/http-server": "^2.3.0",
    "@dcl/job-component": "^0.3.5",
    "@dcl/metrics": "^1.0.1",
    "@dcl/pg-component": "^0.2.0",
    "@dcl/queue-consumer-component": "^3.0.5",
    "@dcl/redis-component": "^3.1.3",
    "@dcl/schema-validator-component": "^1.0.1",
    "@dcl/schemas": "^26.1.0",
    "@dcl/sns-component": "^3.1.5",
    "@dcl/sqs-component": "^2.2.5",
    "@dcl/thegraph-component": "^0.1.2",
    "@ensdomains/eth-ens-namehash": "^2.0.15",
    "@types/busboy": "^1.5.3",
    "@well-known-components/env-config-provider": "^1.2.0",
    "@well-known-components/interfaces": "^1.5.2",
    "@well-known-components/logger": "^3.1.3",
    "@well-known-components/nats-component": "^2.0.0",
    "aws-sdk": "^2.1545.0",
    "bcrypt": "^6.0.0",
    "busboy": "^1.6.0",
    "cron": "^3.1.6",
    "eth-connect": "^6.2.4",
    "file-type": "^16",
    "livekit-server-sdk": "^2.10.1",
    "lru-cache": "^10.2.0",
    "p-queue": "^6.6.2"
  },
  "devDependencies": {
    "@dcl/eslint-config": "^2.2.1",
    "@dcl/test-helpers": "^0.2.0",
    "@redocly/cli": "^1.25.14",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29",
    "@types/node": "^24",
    "dcl-catalyst-client": "^21.11.0",
    "form-data": "4.0.5",
    "jest": "^29",
    "nodemon": "^3.1.11",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none",
    "tabWidth": 2
  }
}
